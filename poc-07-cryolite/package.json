{
  "name": "@chevp/cryolite",
  "version": "0.1.0",
  "description": "Node + browser library that consumes frost-engine-api (poc-06 lineage) and renders it through three.js. Compiles its own wasm from src/ + the vendored nuna-middleware submodule.",
  "type": "module",
  "main": "lib/index.js",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib/index.js",
    "lib/engine.mjs",
    "lib/engine.wasm",
    "lib/engine.data",
    "README.md"
  ],
  "scripts": {
    "build": "./build.sh",
    "smoke:node": "node examples/node/smoke.js",
    "serve:browser": "python3 -m http.server -d examples/browser 8080"
  },
  "peerDependencies": {
    "three": "^0.165.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "private": true
}
