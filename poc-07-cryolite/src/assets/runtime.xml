<?xml version="1.0" encoding="UTF-8"?>
<!--
    WASM Frost Showcase + nuna-middleware - three.js Runtime Configuration

    Same orchestration shape as poc-05 (scene URI + scene-scope Lua scripts),
    but the declared renderer is three.js. The wasm side does not know about
    three.js — it just emits entity transforms; the browser shell wires three.js
    to those transforms each frame. The nuna-middleware C ABI is also linked
    into the same wasm module and surfaced read-only in the HUD.
-->
<synth version="1.0" author="chevp">
<runtimeRenderer version="1.0">

    <metadata>
        <name>WASM Frost + nuna-middleware Showcase</name>
        <client>web-assembly-playground</client>
        <platform>web</platform>
    </metadata>

    <renderer>
        <api type="threejs" version="0.165"/>
        <window width="800" height="600"/>
    </renderer>

    <scene uri="file:///assets/scene.xml"/>

    <scripts>
        <script uri="file:///assets/scene.script.lua" scope="scene"/>
    </scripts>

</runtimeRenderer>
</synth>
